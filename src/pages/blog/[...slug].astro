---
import { getCollection } from 'astro:content';
import V2Layout from '../../layouts/V2Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<V2Layout title={`${post.data.title} — Freddie Kealy`} description={post.data.description} waveAmp={0.35}>
  <article class="post">
    <header class="post-header">
      <a class="post-back" href="/blog" data-hover>← All posts</a>
      <h1 class="post-heading" data-fade>{post.data.title}</h1>
      <div class="post-meta" data-fade>
        <time datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString('en-GB', { day: '2-digit', month: 'long', year: 'numeric' })}
        </time>
        <span class="meta-sep">·</span>
        <span>{post.data.author}</span>
        {post.data.tags.length > 0 && (
          <>
            <span class="meta-sep">·</span>
            <span>{post.data.tags.join(' · ')}</span>
          </>
        )}
      </div>
    </header>

    <div class="prose-dark" data-fade>
      <Content />
    </div>

    <footer class="post-footer">
      <a class="ghost-link" href="/blog" data-hover>← All posts</a>
    </footer>
  </article>

  <style is:global>
    .post {
      max-width: 760px;
      margin: 0 auto;
      padding: 9rem clamp(1.25rem, 4vw, 3rem) clamp(4rem, 8vw, 7rem);
      position: relative;
      z-index: 2;
    }
    .post-back {
      display: inline-block;
      font-family: var(--font-mono);
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: var(--ink-dim);
      text-decoration: none;
      margin-bottom: clamp(1.5rem, 4vw, 2.5rem);
      transition: color 0.25s;
    }
    .post-back:hover { color: var(--accent); }
    .post-heading {
      font-size: clamp(2.2rem, 6.5vw, 4.5rem);
      font-weight: 600;
      line-height: 1.05;
      letter-spacing: -0.02em;
      margin-bottom: clamp(1.2rem, 3vw, 2rem);
    }
    .post-meta {
      font-family: var(--font-mono);
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--ink-dim);
      display: flex;
      flex-wrap: wrap;
      gap: 0.6rem;
      padding-bottom: clamp(2rem, 5vw, 3.5rem);
      border-bottom: 1px solid var(--line);
      margin-bottom: clamp(2rem, 5vw, 3.5rem);
    }
    .meta-sep { color: var(--accent); }

    .prose-dark {
      font-size: 1.1rem;
      line-height: 1.8;
      color: var(--ink);
    }
    .prose-dark p { margin-bottom: 1.5rem; }
    .prose-dark h2 {
      font-size: clamp(1.5rem, 3.5vw, 2.1rem);
      font-weight: 600;
      letter-spacing: -0.01em;
      margin: 3rem 0 1rem;
    }
    .prose-dark h3 {
      font-size: clamp(1.2rem, 2.8vw, 1.5rem);
      font-weight: 600;
      margin: 2.2rem 0 0.8rem;
    }
    .prose-dark a {
      color: var(--accent);
      text-decoration: underline;
      text-decoration-thickness: 1px;
      text-underline-offset: 3px;
    }
    .prose-dark a:hover { text-decoration-thickness: 2px; }
    .prose-dark ul, .prose-dark ol {
      margin: 0 0 1.5rem 1.4rem;
    }
    .prose-dark li { margin-bottom: 0.5rem; }
    .prose-dark li::marker { color: var(--accent); }
    .prose-dark strong { color: var(--ink); font-weight: 600; }
    .prose-dark em { color: var(--ink); }
    .prose-dark blockquote {
      border-left: 2px solid var(--accent);
      padding: 0.4rem 0 0.4rem 1.4rem;
      margin: 2rem 0;
      color: var(--ink-dim);
      font-style: italic;
    }
    .prose-dark code {
      font-family: var(--font-mono);
      font-size: 0.88em;
      background: var(--bg-soft);
      border: 1px solid var(--line);
      padding: 0.15rem 0.45rem;
      border-radius: 4px;
    }
    .prose-dark pre {
      background: var(--bg-soft);
      border: 1px solid var(--line);
      padding: 1.4rem;
      overflow-x: auto;
      margin: 0 0 1.5rem;
      border-radius: 6px;
    }
    .prose-dark pre code {
      background: none;
      border: none;
      padding: 0;
    }
    .prose-dark img {
      max-width: 100%;
      height: auto;
      border: 1px solid var(--line);
      margin: 2rem 0;
    }
    .prose-dark hr {
      border: none;
      border-top: 1px solid var(--line);
      margin: 3rem 0;
    }

    .post-footer { margin-top: clamp(2rem, 5vw, 3rem); }
  </style>

  <script>
    import gsap from 'gsap';
    import { reduceMotion } from '../../scripts/v2';

    if (!reduceMotion) {
      const tl = gsap.from('[data-fade]', {
        y: 30,
        opacity: 0,
        duration: 0.8,
        stagger: 0.12,
        ease: 'power3.out',
        delay: 0.1,
      });

      setTimeout(() => {
        if (tl.progress() < 1) tl.progress(1);
      }, 3000);
    }
  </script>
</V2Layout>
